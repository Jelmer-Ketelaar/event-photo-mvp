{
  "name": "@event-photo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:native": "tsc --noEmit && vite build --mode native",
    "native:assets": "CLANG_MODULE_CACHE_PATH=/tmp/eventframe-swift-cache swift scripts/generate_brand_assets.swift",
    "cap:sync": "npm run build:native && cap sync",
    "cap:sync:ios": "npm run build:native && cap sync ios",
    "cap:sync:android": "npm run build:native && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@capacitor/android": "^8.3.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@event-photo/shared": "0.1.0",
    "fflate": "^0.8.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-router-dom": "^7.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vitest": "^4.1.1"
  }
}
