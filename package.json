{
  "name": "eventframe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @event-photo/web",
    "dev:web:lan": "npm run dev:lan --workspace @event-photo/web",
    "dev:api": "npm run dev --workspace @event-photo/api",
    "dev:api:lan": "npm run dev:lan --workspace @event-photo/api",
    "deploy": "npm run deploy --workspace @event-photo/api",
    "deploy:dry-run": "npm run deploy:dry-run --workspace @event-photo/api",
    "db:migrate:remote": "npm run db:migrate:remote --workspace @event-photo/api",
    "live": "node scripts/go-live.mjs",
    "live:dry-run": "node scripts/go-live.mjs --dry-run",
    "native:assets": "npm run native:assets --workspace @event-photo/web",
    "native:sync": "npm run cap:sync --workspace @event-photo/web",
    "native:sync:ios": "npm run cap:sync:ios --workspace @event-photo/web",
    "native:sync:android": "npm run cap:sync:android --workspace @event-photo/web",
    "native:open:ios": "npm run cap:open:ios --workspace @event-photo/web",
    "native:open:android": "npm run cap:open:android --workspace @event-photo/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@event-photo/shared": "^0.1.0",
    "fflate": "^0.8.2"
  }
}
